; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Miarritze"
run/main_scene="res://src/ui/boot/boot.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")

[autoload]

GameState="*res://src/autoload/game_state.gd"
ScoreManager="*res://src/autoload/score_manager.gd"
AudioManager="*res://src/autoload/audio_manager.gd"
LeaderboardClient="*res://src/autoload/leaderboard_client.gd"
SceneRouter="*res://src/autoload/scene_router.gd"
QaCapture="*res://src/autoload/qa_capture.gd"

[gui]

theme/custom="res://assets/ui/theme.tres"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/handheld/orientation=4
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[input_devices]

pointing/emulate_touch_from_mouse=true

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/canvas_textures/default_texture_filter=0
textures/vram_compression/import_etc2_astc=true
